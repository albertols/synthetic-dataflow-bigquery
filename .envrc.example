# Per-machine environment vars, auto-loaded by direnv on `cd` into this repo.
#
# Setup (one-time per machine):
#   brew install direnv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc   # or your shell rc
#   cp .envrc.example .envrc
#   # edit .envrc with the values for THIS machine
#   direnv allow
#
# After that, every shell that `cd`s into this repo (and every IDE that
# respects direnv — PyCharm with the EnvFile or direnv plugin does) picks
# these up automatically. Leave this template at sensible defaults; the
# real `.envrc` is gitignored.

# -----------------------------------------------------------------------------
# Corporate egress — needed when running outside GCP (laptop, M4, etc.) and
# any outbound HTTPS hits an internal proxy. Set ONLY if your machine sits
# behind a corp proxy; on a public network leave commented out.
# -----------------------------------------------------------------------------
# For db.com networks, the working egress proxy for googleapis.com is the
# data-ops cluster — NOT the general browsing proxy (`sp-surf-*`).
# export HTTP_PROXY="http://sdod3-proxy.intranet.db.com:8080"
# export HTTPS_PROXY="http://sdod3-proxy.intranet.db.com:8080"
# export NO_PROXY="localhost,127.0.0.1,metadata.google.internal"

# -----------------------------------------------------------------------------
# Custom CA bundle — uncomment only if your proxy does TLS MITM and the
# default `certifi` bundle isn't trusted. Path varies per machine.
# -----------------------------------------------------------------------------
# export REQUESTS_CA_BUNDLE="/etc/ssl/certs/corporate-ca-bundle.pem"
# export SSL_CERT_FILE="$REQUESTS_CA_BUNDLE"

# -----------------------------------------------------------------------------
# BigQuery client timeout (seconds). Default is 50; bump if you're on a slow
# link and the preflight `SELECT 1` legitimately needs longer.
# -----------------------------------------------------------------------------
# export BIGQUERY_TIMEOUT=120

# -----------------------------------------------------------------------------
# Python — keep buffered output off so logs appear in real time.
# -----------------------------------------------------------------------------
export PYTHONUNBUFFERED=1

# -----------------------------------------------------------------------------
# Corporate JFrog / Artifactory — for the L4 GPU worker image (M1 §10).
# Get exact values from the platform team or your prior SCIO build.yaml.
# Leave RELEASER_* unset unless you're actually pushing — keeps creds out of
# regular shells.
# -----------------------------------------------------------------------------
# export ARTIFACTORY_HOSTNAME="artifactory.intranet.db.com"
# export ARTIFACTORY_NAMESPACE="pwcclakees"
# export ARTIFACTORY_RELEASER_USER="<service-account>"
# export ARTIFACTORY_RELEASER_PS="<token>"

# -----------------------------------------------------------------------------
# GCP target for Dataflow GPU jobs (M1 §10 / §11).
# -----------------------------------------------------------------------------
# export GCP_REGION="europe-west3"
# export GCP_ZONE="europe-west3-b"
